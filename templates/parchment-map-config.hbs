<div class="standard-form">
	<p class="hint">{{localize 'SCORPPARCH.Config.Hint'}}</p>

	<div class="form-group">
		<label>{{localize 'SCORPPARCH.Config.Theme'}}</label>
		<div class="form-fields">
			<select name="theme">
				{{#each themes}}
				<option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>
				{{/each}}
			</select>
		</div>
		<p class="hint">{{localize 'SCORPPARCH.Config.ThemeHint'}}</p>
	</div>

	<div class="form-group">
		<label>{{localize 'SCORPPARCH.Config.Scene'}}</label>
		<div class="form-fields">
			<select name="sceneId">
				<option value="">{{localize 'SCORPPARCH.Config.ViewedScene'}}</option>
				{{#each scenes}}
				<option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
				{{/each}}
			</select>
		</div>
		<p class="hint">{{localize 'SCORPPARCH.Config.SceneHint'}}</p>
	</div>

	<div class="form-group">
		<label>{{localize 'SCORPPARCH.Config.Actor'}}</label>
		<div class="form-fields">
			<select name="actorId">
				<option value="">{{localize 'SCORPPARCH.Config.OwnCharacter'}}</option>
				{{#each actors}}
				<option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
				{{/each}}
			</select>
		</div>
		<p class="hint">{{localize 'SCORPPARCH.Config.ActorHint'}}</p>
	</div>

	<div class="form-group">
		<label>{{localize 'SCORPPARCH.Config.Zoom'}}</label>
		<div class="form-fields">
			<input type="number" name="zoom" value="{{zoom}}" step="0.25" min="1" max="8" />
		</div>
		<p class="hint">{{localize 'SCORPPARCH.Config.ZoomHint'}}</p>
	</div>

	<footer class="form-footer">
		<button type="submit"><i class="fas fa-floppy-disk"></i> {{localize 'SCORPPARCH.Config.Save'}}</button>
	</footer>
</div>
