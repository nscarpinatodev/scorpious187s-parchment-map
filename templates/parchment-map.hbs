{{!-- Scorpious187's Parchment Map — a scene rendered inside a themed frame
      (aged parchment scroll, sci-fi tablet, ...). Text-free: just the map,
      the marker, and the icon tools. In the rotated orientation the frame
      texture turns 90° under the map while the map stays upright. --}}
<div class="pmap-scroll {{themeClass}}{{#if rotated}} rotated{{/if}}" style="{{scrollStyle}}">
	<div class="pmap-frame"></div>
	<div class="pmap-content">
		{{#if available}}
		<div class="pmap-viewport" data-fx="{{fx}}" data-fy="{{fy}}" data-zoom="{{defaultZoom}}">
			{{!-- The canvas pans/zooms as one unit so the ink/grain treatment
			      only covers the map itself, never the bare paper around it. --}}
			<div class="pmap-canvas">
				<img class="pmap-scene" src="{{bgSrc}}" alt="" draggable="false" />
				{{#each tiles}}
				<img class="pmap-tile" src="{{src}}" alt="" draggable="false"
					style="left:{{left}}%;top:{{top}}%;width:{{width}}%;height:{{height}}%;opacity:{{alpha}};{{#if rotation}}transform:rotate({{rotation}}deg);transform-origin:{{originX}}% {{originY}}%;{{/if}}" />
				{{/each}}
				<div class="pmap-ink"></div>
				<div class="pmap-grain"></div>
			</div>
			<div class="pmap-vignette"></div>
			{{#if hasToken}}<div class="pmap-marker" data-tooltip="{{actorName}}"></div>{{/if}}
		</div>

		<div class="pmap-tools">
			<button type="button" class="pmap-tool" data-action="zoomMap" data-dir="1"
				data-tooltip="{{localize 'SCORPPARCH.ZoomIn'}}">
				<i class="fas fa-magnifying-glass-plus"></i>
			</button>
			<button type="button" class="pmap-tool" data-action="zoomMap" data-dir="-1"
				data-tooltip="{{localize 'SCORPPARCH.ZoomOut'}}">
				<i class="fas fa-magnifying-glass-minus"></i>
			</button>
			<button type="button" class="pmap-tool" data-action="recenterMap"
				data-tooltip="{{localize 'SCORPPARCH.Recenter'}}">
				<i class="fas fa-crosshairs"></i>
			</button>
			<button type="button" class="pmap-tool" data-action="rotateMap"
				data-tooltip="{{localize 'SCORPPARCH.Rotate'}}">
				<i class="fas fa-rotate-right"></i>
			</button>
			<button type="button" class="pmap-tool" data-action="closeMap"
				data-tooltip="{{localize 'SCORPPARCH.Close'}}">
				<i class="fas fa-power-off"></i>
			</button>
		</div>
		{{else}}
		<div class="pmap-empty" data-tooltip="{{localize 'SCORPPARCH.EmptyHint'}}">
			<i class="fas fa-map-location-dot"></i>
		</div>
		{{/if}}
	</div>
	{{#if hasFront}}<div class="pmap-frame-front"></div>{{/if}}
</div>
